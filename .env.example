# ─────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES — copy this to .env.local and fill in values
# ─────────────────────────────────────────────────────────────────

# Landlord Database
LANDLORD_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5300/pinetworks_landlord

# Tenant Databases (local dev only — in production these come from Key Vault)
TENANT_ALPHA_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5301/pinetworks_alpha
TENANT_BETA_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5302/pinetworks_beta

# Redis
REDIS_URL=redis://localhost:6179

# NextAuth
AUTH_SECRET="dev-secret-replace-in-production-with-min-32-chars"
AUTH_URL="http://localhost:3000"

# Microsoft Entra ID (Landlord Admin)
AUTH_AZURE_AD_CLIENT_ID="placeholder-client-id"
AUTH_AZURE_AD_CLIENT_SECRET="placeholder-client-secret"
AUTH_AZURE_AD_TENANT_ID="placeholder-tenant-id"

# Key Vault (production only)
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
