  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate:landlord": "drizzle-kit generate --config=drizzle.landlord.config.ts",
    "db:generate:tenant": "drizzle-kit generate --config=drizzle.tenant.config.ts",
    "db:migrate:landlord": "drizzle-kit migrate --config=drizzle.landlord.config.ts",
    "db:migrate:tenant": "drizzle-kit migrate --config=drizzle.tenant.config.ts",
    "db:studio:landlord": "drizzle-kit studio --config=drizzle.landlord.config.ts",
    "db:studio:tenant": "drizzle-kit studio --config=drizzle.tenant.config.ts",
    "db:seed": "tsx lib/db/seed.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
